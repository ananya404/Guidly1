rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // 1. Users collection
    match /users/{userId} {
      // Anyone authenticated can read user profiles (needed for chats, reviews, etc.)
      allow read: if isAuthenticated();
      // Only the specific user can modify their own profile
      allow write: if isOwner(userId);
    }

    // 2. Guides collection
    match /guides/{guideId} {
      // Guide profiles are public to everyone
      allow read: if true;
      // Only the specific guide can modify their own profile
      allow write: if isOwner(guideId);
    }

    // 3. Trips collection
    match /trips/{tripId} {
      // Trips are public to view
      allow read: if true;
      // Only an authenticated guide can create a trip, and they must be set as the guideId
      allow create: if isAuthenticated() && request.resource.data.guideId == request.auth.uid;
      // Only the trip's guide can update or delete it
      allow update, delete: if isAuthenticated() && resource.data.guideId == request.auth.uid;
    }

    // 4. Bookings collection
    match /bookings/{bookingId} {
      // User who booked it or the guide leading the trip can read it
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || resource.data.guideId == request.auth.uid);
      // Authenticated users can create bookings for themselves
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      // Both user and guide can update (e.g., status changes like "cancelled" or "confirmed")
      allow update: if isAuthenticated() && (resource.data.userId == request.auth.uid || resource.data.guideId == request.auth.uid);
      // Only the user who booked can delete (or neither, but usually user)
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    // 5. Reviews collection
    match /reviews/{reviewId} {
      // Reviews are public
      allow read: if true;
      // Authenticated users can write a review
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      // Only the author can modify or delete their review
      allow update, delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    // 6. Chats collection
    match /chats/{chatId} {
      // Users can only read and update chats if they are in the participants array
      allow read: if isAuthenticated() && request.auth.uid in resource.data.participants;
      allow create: if isAuthenticated() && request.auth.uid in request.resource.data.participants;
      allow update: if isAuthenticated() && request.auth.uid in resource.data.participants;
      allow delete: if false; // Chats shouldn't be fully deleted by clients usually
      
      // Messages subcollection within a chat
      match /messages/{messageId} {
        // Read if user is a participant of the parent chat
        allow read: if isAuthenticated() && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
        // Create if participant AND senderId matches their own uid
        allow create: if isAuthenticated() && 
                      request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants && 
                      request.resource.data.senderId == request.auth.uid;
        // Messages are immutable usually
        allow update, delete: if false;
      }
    }

    // 7. Payments collection
    match /payments/{paymentId} {
      // Users can read only their own payments
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      // Payments are exclusively written by securely authenticated Cloud Functions
      allow write: if false; 
    }

    // Default deny for everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
